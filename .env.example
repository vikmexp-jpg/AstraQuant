###############################################################################
# AstraQuant Environment Configuration
#
# Instructions:
# 1. Copy this file to ".env"
# 2. Fill in your own credentials.
# 3. Never commit the ".env" file to Git.
###############################################################################

###############################################################################
# Upstox API Configuration
###############################################################################

# Your Upstox API Key.
# Obtain it from:
# https://developer.upstox.com
UPSTOX_API_KEY=

# Your Upstox API Secret.
# Obtain it from the Upstox Developer Console.
UPSTOX_API_SECRET=

# OAuth Access Token.
#
# This token is generated after completing the Upstox OAuth login flow.
# It expires periodically and must be refreshed when required.
UPSTOX_ACCESS_TOKEN=

###############################################################################
# Telegram Notification Configuration
###############################################################################

# Telegram Bot Token.
#
# Steps:
# 1. Open Telegram.
# 2. Search for @BotFather.
# 3. Create a bot using /newbot.
# 4. Copy the Bot Token provided by BotFather.
#
# Example:
# 123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_BOT_TOKEN=

# Telegram Chat ID.
#
# Steps:
# 1. Start a chat with your bot.
# 2. Send any message (e.g. "Hello").
# 3. Open:
#
# https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
#
# 4. Copy the "chat.id" value.
#
# Example:
# 1027825901
TELEGRAM_CHAT_ID=

###############################################################################
# Future Configuration
###############################################################################

# Discount thresholds for index alerts
# Set these to your desired daily minimums for Telegram Buy alerts.
DISCOUNT_THRESHOLD_NIFTY=10
DISCOUNT_THRESHOLD_SENSEX=30

# Database URL
# DATABASE_URL=

# Paper Trading
# PAPER_TRADING=true

# Maximum Open Positions
# MAX_OPEN_POSITIONS=1

# Log Level
# LOG_LEVEL=INFO